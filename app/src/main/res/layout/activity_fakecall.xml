<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/solid_background"
    android:padding="16dp"
    tools:context="com.project.sheild.FakeCall">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/ic_chevron_right"
            android:rotation="180"
            app:tint="@color/theme_white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fake Call"
            android:textColor="@color/theme_red"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_centerInParent="true" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Caller Name Input Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_bg_solid_white"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <EditText
                        android:id="@+id/caller_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:hint="Enter Caller Name"
                        android:textColor="@color/theme_black"
                        android:textColorHint="#777777"
                        android:textStyle="bold"
                        android:inputType="textPersonName" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Caller Number Input Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_bg_solid_white"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <EditText
                        android:id="@+id/caller_number"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:hint="Enter Caller Number"
                        android:textColor="@color/theme_black"
                        android:textColorHint="#777777"
                        android:textStyle="bold"
                        android:inputType="phone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Image Preview Box -->
            <androidx.cardview.widget.CardView
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="70dp"
                app:cardBackgroundColor="@color/theme_dark_gray"
                app:strokeColor="@color/theme_red"
                app:strokeWidth="2dp">

                <ImageView
                    android:id="@+id/caller_image_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="Caller Image" />
            </androidx.cardview.widget.CardView>

            <!-- Action Buttons -->
            <Button
                android:id="@+id/select_image"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:backgroundTint="@color/theme_white"
                android:textColor="@color/theme_red"
                android:text="Select Caller Image"
                android:textStyle="bold"
                app:strokeColor="@color/theme_red"
                app:strokeWidth="1dp" />

            <Button
                android:id="@+id/start_fake_call"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:backgroundTint="@color/theme_red"
                android:textColor="@color/theme_white"
                android:text="Start Fake Call"
                android:textStyle="bold" />

            <Button
                android:id="@+id/default_fake_call"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:backgroundTint="@color/theme_black"
                android:textColor="@color/theme_white"
                android:text="Default Fake Call"
                android:textStyle="bold"
                app:strokeColor="@color/theme_light_gray"
                app:strokeWidth="1dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
